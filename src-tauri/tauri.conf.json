{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ENote",
  "version": "1.2.0",
  "identifier": "net.easycloudcn.enote",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "maximized": true,
        "fullscreen": false,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: tauri:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/help/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^https?://"
    },
    "updater": {
      "endpoints": [
        "https://github.com/easynet-cn/enote/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxRjA5REJBRDMyNEYyRTUKUldUbDhpVFR1cDN3NFdKYWZEU2VnNHEvQXlaQy9nU0J0emdsUGtFQzhnaFNlZTY2eE1FaWNEVG4K"
    }
  }
}