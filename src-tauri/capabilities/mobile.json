{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Capability for mobile platforms",
  "platforms": ["android", "iOS"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "opener:default",
    "fs:default",
    "fs:allow-write-text-file",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
